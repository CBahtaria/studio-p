    "// Hide Mac-OS bar on Pake — Pake provides its own native chrome",
    "document.getElementById('mac-bar') && (document.getElementById('mac-bar').style.display = 'none');"
  ],
  "user_agent": "StudioP/1.0 Pake/3.0",
  "safe_domain_list": [
    "studio-p.vercel.app",
    "studiop.sz",
    "supabase.co",
    "accounts.google.com",
    "appleid.apple.com"
  ]
}
