{
  "name": "Studio P",
  "url": "https://studio-p.vercel.app",
  "width": 1280,
  "height": 800,
  "resizable": true,
  "title": "Studio P — Barbershop",
  "identifier": "sz.studiop.app",
  "icon": "assets/icon.png",
  "always_on_top": false,
  "fullscreen": false,
  "targets": ["macos", "windows", "linux"],
