# ════════════════════════════════════════════════
# STUDIO P — Environment Variables
# Copy to .env.local and fill in your values. Updated env vars in Vercel.
# NEVER commit .env.local to source control.
# ════════════════════════════════════════════════

# ── Supabase (supabase.com → project → Settings → API) ──
# Safe to expose — protected by RLS policies
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Google OAuth (console.cloud.google.com → Credentials) ──
# Authorised JS origins: http://localhost:5173, https://studio-p.vercel.app
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Apple Sign In (developer.apple.com) ──
# Requires App ID + Service ID + domain verification
VITE_APPLE_SERVICE_ID=sz.studiop.app
VITE_APPLE_REDIRECT_URI=https://studio-p.vercel.app/auth/callback

# ── App Config ──
VITE_APP_NAME=Studio P
VITE_APP_ENV=development
VITE_PUBLIC_URL=http://localhost:5173
VITE_WHATSAPP_NUMBER=26879333760

# ── Feature Flags ──
VITE_ENABLE_DEMO_MODE=true       # MUST be false in production
VITE_ENABLE_DEV_LOG=false        # true shows DevLogPanel (dev only)

# ════════════════════════════════════════════════
# SERVER-SIDE ONLY — Set in Vercel / Supabase dashboard.
# NEVER prefix with VITE_ (would expose to browser).
# ════════════════════════════════════════════════

# Supabase service role key (bypasses RLS — for edge functions only)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Email provider (resend.com → free tier: 3k emails/month)
# RESEND_API_KEY=re_...

# OAuth secrets (set in Supabase Auth dashboard, not here)
# GOOGLE_CLIENT_SECRET=...
# APPLE_CLIENT_SECRET=...